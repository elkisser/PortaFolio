---
/**
 * About in English (`/en/about`) — real, indexable route (Req 1.4, design.md
 * §5.1). About absorbs the stack in context, GitHub as curated evidence and the
 * refined experience timeline; it closes with Contact as the final CTA
 * (design.md §4.6, narrative arc).
 *
 * Editorial section numbering: 01 About · 02 Stack · 03 GitHub ·
 * 04 Experience · 05 Contact.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import AboutIntro from "../../components/about/AboutIntro.astro";
import Stack from "../../components/about/Stack.astro";
import GitHubEvidence from "../../components/about/GitHubEvidence.astro";
import Timeline from "../../components/about/Timeline.astro";
import Contact from "../../components/Contact.astro";
import { useTranslations } from "../../lib/i18n";

const t = useTranslations("en");
---

<BaseLayout lang="en" title={t.about_title} description={t.about_lead}>
  <main id="main" tabindex="-1">
    <AboutIntro lang="en" index="01" />
    <Stack lang="en" index="02" />
    <GitHubEvidence lang="en" index="03" />
    <Timeline lang="en" index="04" />
    <Contact lang="en" index="05" />
  </main>
</BaseLayout>
