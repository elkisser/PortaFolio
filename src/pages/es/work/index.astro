---
/**
 * Índice de Work en español (`/es/work`) — ruta real e indexable (Req 5.1,
 * design.md §5.1). Cableado a `BaseLayout` con `lang="es"` y al `WorkIndex`, que
 * lee la colección `work`, filtra por idioma y presenta el índice editorial con
 * filtro por categoría (Req 5.4). Las páginas de detalle (`/work/[slug]`) llegan
 * en la tarea 11.
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import WorkIndex from "../../../components/work/WorkIndex.astro";
import { useTranslations } from "../../../lib/i18n";

const t = useTranslations("es");
---

<BaseLayout lang="es" title={t.work_title} description={t.work_desc}>
  <main id="main" tabindex="-1">
    <WorkIndex lang="es" />
  </main>
</BaseLayout>
