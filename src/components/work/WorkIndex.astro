---
/**
 * WorkIndex — índice editorial de case studies (design.md §5.1/§5.4, §7.1; Req
 * 5.1/5.4).
 *
 * Lee la colección `work`, selecciona y ordena las entradas del idioma activo
 * (lógica pura `selectWorkIndex`) y las presenta como una lista editorial de
 * `WorkCard` (un sumario de revista, no una grilla 2×N de cards idénticas — el
 * anti-patrón que el brief pide evitar, design.md §1.2/§4.4).
 *
 * **Filtro por categoría con estética integrada (Req 5.4):** NO son "pills"
 * genéricas. Es una fila de etiquetas en JetBrains Mono (uppercase, tracking de
 * firma) con su conteo, separadas por hairlines; la categoría activa se señala
 * con el acento ámbar + subrayado (no solo color → a11y). Solo se ofrecen las
 * categorías que realmente tienen proyectos (`collectCategories`), evitando
 * filtros que llevan a un índice vacío.
 *
 * Hidratación / progressive enhancement (design.md §6.2): el filtrado es una
 * **mejora**. El custom element `<work-index>` se hidrata en *idle* (equivalente
 * vanilla a `client:idle`, sin runtime de framework, coste objetivo < 2 KB) y
 * solo entonces revela la barra de filtro (que arranca `hidden`). Sin JS, la
 * barra permanece oculta y **todas** las tarjetas quedan visibles y accesibles:
 * el contenido nunca depende del filtro (Req 5.4 sin romper a11y). La decisión de
 * coincidencia es la misma lógica pura `categoryMatches`, reimplementada inline
 * en el cliente para no arrastrar el esquema (zod) al bundle de la isla.
 *
 * Reveal on-scroll: cada `WorkCard` lleva `[data-reveal]`; la isla `Motion`
 * (montada en `BaseLayout`) los descubre y revela con la firma de movimiento del
 * sistema, respetando reduced-motion (Req 10).
 */
import { getCollection } from "astro:content";
import Section from "../primitives/Section.astro";
import Text from "../primitives/Text.astro";
import Mono from "../primitives/Mono.astro";
import WorkCard from "./WorkCard.astro";
import {
  selectWorkIndex,
  collectCategories,
  CATEGORY_LABELS,
  ALL_CATEGORY,
} from "../../lib/work";
import { useTranslations, isLocale, DEFAULT_LOCALE, type Locale } from "../../lib/i18n";

interface Props {
  /** Idioma de la página → copy localizado, filtrado por idioma y enlaces. */
  lang?: string;
}

const { lang: rawLang = DEFAULT_LOCALE }: Props = Astro.props;
const lang: Locale = isLocale(rawLang) ? rawLang : DEFAULT_LOCALE;
const t = useTranslations(lang);

// Lee la colección y selecciona/ordena las entradas del idioma activo (Req 5.1).
const allWork = await getCollection("work");
const entries = selectWorkIndex(allWork, lang);

// Categorías presentes (con conteo) para el filtro editorial (Req 5.4).
const categories = collectCategories(entries);
const hasFilter = categories.length > 1; // 0–1 categoría → filtrar no aporta.
---

<work-index id="work" data-work-index>
  <Section index="01" label={t.nav_work} aria-labelledby="work-index-title">
    <header class="work__head">
      <Text as="h1" id="work-index-title" font="display" step="3" class="work__title">
        {t.work_title}
      </Text>
      <Text class="work__desc" tone="dim" step="1" measure>{t.work_desc}</Text>
    </header>

    {
      hasFilter && (
        <div class="filter" role="group" aria-label={t.nav_work} data-filter hidden>
          <button
            type="button"
            class="filter__btn"
            data-filter-btn
            data-category={ALL_CATEGORY}
            aria-pressed="true"
          >
            <span class="filter__name">{t.filter_all}</span>
            <span class="filter__count">{entries.length}</span>
          </button>
          {categories.map((item) => (
            <button
              type="button"
              class="filter__btn"
              data-filter-btn
              data-category={item.category}
              aria-pressed="false"
            >
              <span class="filter__name">{CATEGORY_LABELS[item.category]}</span>
              <span class="filter__count">{item.count}</span>
            </button>
          ))}
        </div>
      )
    }

    {
      entries.length > 0 ? (
        <ol class="work__list" data-work-list>
          {entries.map((entry, i) => (
            <li class="work__item">
              <WorkCard entry={entry} lang={lang} index={i + 1} />
            </li>
          ))}
        </ol>
      ) : (
        <Mono class="work__empty">{t.work_desc}</Mono>
      )
    }

    <!-- Estado del filtro anunciado a lectores de pantalla (a11y, Req 5.4). -->
    <p class="visually-hidden" aria-live="polite" data-filter-status></p>
  </Section>
</work-index>

<style>
  .work__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-block-end: var(--space-xl);
  }

  .work__title {
    margin: 0;
  }

  .work__desc {
    margin: 0;
  }

  /* ---------------------------------------------------------------------------
     Filtro editorial (Req 5.4): fila de etiquetas mono con conteo, separadas por
     hairlines. NO son pills: sin relleno de cápsula ni fondo; el estado activo se
     marca con ámbar + subrayado (no solo color → a11y). Oculto hasta hidratar.
     --------------------------------------------------------------------------- */
  .filter {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-xs) var(--space-lg);
    margin-block-end: var(--space-xl);
    padding-block-end: var(--space-sm);
    border-block-end: 1px solid var(--line);
  }

  .filter__btn {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-3xs);
    padding: 0;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    color: var(--paper-dim);
    background: transparent;
    border: 0;
    border-block-end: 1px solid transparent;
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease);
  }

  .filter__btn:hover {
    color: var(--paper);
  }

  /* Conteo en un tono más tenue: jerarquía sin segundo color. */
  .filter__count {
    font-size: 0.75em;
    color: var(--line);
  }

  .filter__btn:hover .filter__count {
    color: var(--paper-dim);
  }

  /* Activo: acento ámbar + subrayado (no depende solo del color — a11y). */
  .filter__btn[aria-pressed="true"] {
    color: var(--amber);
    border-block-end-color: var(--amber);
  }

  .filter__btn[aria-pressed="true"] .filter__count {
    color: var(--amber-hi);
  }

  /* ---------------------------------------------------------------------------
     Lista del índice: reset de <ol>; las hairlines de separación las aporta cada
     WorkCard (continuidad visual entre entradas).
     --------------------------------------------------------------------------- */
  .work__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .work__empty {
    display: block;
    padding-block: var(--space-lg);
  }

  /* Oculto accesible: visible para lectores de pantalla, fuera de pantalla. */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  /**
   * `<work-index>` — comportamiento vanilla del filtro del índice de Work
   * (design.md §5.4, §6.2). Se hidrata en *idle* (equivalente a `client:idle` sin
   * runtime de framework) para no competir con el FCP. Revela la barra de filtro
   * y filtra las tarjetas por categoría en cliente.
   *
   * La decisión de coincidencia replica la lógica pura `categoryMatches`
   * (`lib/work.ts`, testeada): `'all'` acepta todo; una categoría concreta acepta
   * la tarjeta si la declara en `data-category` (lista separada por espacios). Se
   * reimplementa aquí —en vez de importar `lib/work`— para no arrastrar el
   * esquema (zod) al bundle de la isla.
   */
  class WorkIndex extends HTMLElement {
    private buttons: HTMLButtonElement[] = [];
    private cards: HTMLElement[] = [];
    private filter: HTMLElement | null = null;
    private status: HTMLElement | null = null;

    connectedCallback(): void {
      const idle: (cb: () => void) => void =
        "requestIdleCallback" in window
          ? (cb) => window.requestIdleCallback(cb)
          : (cb) => window.setTimeout(cb, 1);
      idle(() => this.init());
    }

    private init(): void {
      this.filter = this.querySelector<HTMLElement>("[data-filter]");
      this.status = this.querySelector<HTMLElement>("[data-filter-status]");
      this.buttons = Array.from(
        this.querySelectorAll<HTMLButtonElement>("[data-filter-btn]"),
      );
      this.cards = Array.from(this.querySelectorAll<HTMLElement>("[data-work-card]"));

      // Sin filtro útil (0–1 categoría) no hay nada que hidratar.
      if (!this.filter || this.buttons.length === 0) return;

      // Revela la barra de filtro: a partir de aquí, la mejora está activa.
      this.filter.removeAttribute("hidden");

      this.addEventListener("click", this.onClick);
    }

    private onClick = (event: MouseEvent): void => {
      const target = event.target as HTMLElement | null;
      const btn = target?.closest<HTMLButtonElement>("[data-filter-btn]");
      if (!btn) return;
      this.apply(btn.dataset.category ?? "all");
    };

    /** ¿El usuario pidió menos movimiento? (contrato global, Req 10.2/10.3). */
    private prefersReducedMotion(): boolean {
      return window.matchMedia?.("(prefers-reduced-motion: reduce)").matches ?? false;
    }

    /**
     * Aplica el filtro: misma decisión que `categoryMatches` (lib/work.ts).
     *
     * Efecto "carrusel" (gesto de entrada del sistema, design.md §4.5/§10): al
     * cambiar de categoría se fija el estado final al instante (sin layout-shift
     * raro) y las tarjetas resultantes RE-ENTRAN deslizándose desde la derecha
     * con un leve escalonado (Web Animations API, mismo `ease` que el sistema).
     * Solo opacidad/transform → no toca el layout ni provoca CLS. Bajo
     * `prefers-reduced-motion` no se anima: el filtro es un simple toggle visible
     * y accesible (Req 10.2/10.4). Cada cambio cancela animaciones en vuelo para
     * que no queden transforms colgados al alternar rápido.
     */
    private apply(active: string): void {
      for (const btn of this.buttons) {
        btn.setAttribute("aria-pressed", String(btn.dataset.category === active));
      }

      const reduce = this.prefersReducedMotion();
      let visible = 0;
      const shown: HTMLElement[] = [];

      for (const card of this.cards) {
        const categories = (card.dataset.category ?? "").split(/\s+/).filter(Boolean);
        const match = active === "all" || categories.includes(active);
        const item = (card.closest("li") ?? card) as HTMLElement;
        // Cancela cualquier animación previa → vuelve al estado natural (sin
        // `fill`), evitando opacidad/transform residual al filtrar rápido.
        item.getAnimations?.().forEach((a) => a.cancel());
        item.toggleAttribute("hidden", !match);
        if (match) {
          visible += 1;
          shown.push(item);
        }
      }

      if (!reduce) {
        shown.forEach((item, i) => {
          item.animate(
            [
              { opacity: 0, transform: "translateX(28px)" },
              { opacity: 1, transform: "translateX(0)" },
            ],
            {
              duration: 450,
              // Escalonado acotado: con muchas tarjetas no se hace eterno.
              delay: Math.min(i, 6) * 70,
              easing: "cubic-bezier(0.22, 1, 0.36, 1)",
              // `backwards`: aplica el primer keyframe (opacity 0) durante el
              // delay → la tarjeta no parpadea en su estado final antes de entrar.
              fill: "backwards",
            },
          );
        });
      }

      if (this.status) this.status.textContent = String(visible);
    }
  }

  if (!customElements.get("work-index")) {
    customElements.define("work-index", WorkIndex);
  }
</script>
