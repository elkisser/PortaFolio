---
/**
 * Repo — repositorio (metáfora de libro/cuaderno de código, como el icono de
 * repositorio de GitHub). Tapa rectangular + lomo vertical, esquinas vivas
 * coherentes con las hairlines (design.md §4.5).
 */
import Icon from "./Icon.astro";
import type { Props } from "./Icon.astro";

const props: Props = Astro.props;
---

<Icon {...props}>
  <rect x="5" y="3" width="14" height="18"></rect>
  <line x1="9" y1="3" x2="9" y2="21"></line>
</Icon>
